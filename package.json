{
  "name": "smart-ledger-backend",
  "version": "1.0.0",
  "description": "Smart Mini-Ledger API — NestJS + PostgreSQL + Redis",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
